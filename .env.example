# Database
DATABASE_URL=postgresql://entix_books:PASSWORD@DB_HOST:5432/entix_books?sslmode=require

# better-auth
BETTER_AUTH_SECRET=  # 32+ char random string · openssl rand -hex 32
BETTER_AUTH_URL=https://api.entix.io
FRONTEND_URL=https://entix.io
API_URL=https://api.entix.io

# Email · required in production for invoice/quote delivery
# RESEND_API_KEY=
# EMAIL_FROM=ENSIDEX LLC <billing@ensidex.com>

# Inbound bills mailbox · the email provider must forward parsed messages to /api/inbox/webhook
# INBOUND_BILLS_EMAIL=bills+{slug}@entix.io
# INBOUND_EMAIL_DOMAIN=entix.io
# INBOUND_EMAIL_PROVIDER=resend
# INBOX_WEBHOOK_TOKEN=  # long shared secret sent as X-Inbox-Token

# Payment gateways · server-managed fallback for ENSIDEX LLC / US market
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_CLIENT_ID=ca_...     # optional: only needed for Stripe Connect onboarding
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live

# Optional · later
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# AI agent bridge · server-side only
# ENTIX_N8N_AGENT_WEBHOOK_URL=https://w.fc.sa/webhook/en-wf-entix-books-agent-chat-v01
# ENTIX_N8N_WEBHOOK_SECRET=  # shared secret sent as X-Entix-Webhook-Secret
# OPENROUTER_API_KEY=        # hosted AI fallback when n8n is unavailable
# OPENROUTER_AGENT_MODEL=

# Server
PORT=3000
NODE_ENV=production
